<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
<title>Tennis Master</title>
<meta name="description" content="Upload a match screenshot, get independent research and a paper-trade read against the market price." />
<meta name="theme-color" content="#0B1420" />

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500;600&family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">

<style>
:root {
  --ink: #0B1420;
  --ink-soft: #131F2E;
  --ink-raised: #182838;
  --line: #223244;
  --chalk: #F2F4F3;
  --chalk-dim: #8FA0B3;
  --green: #34C77B;
  --green-soft: rgba(52,199,123,0.14);
  --amber: #E0A83E;
  --amber-soft: rgba(224,168,62,0.14);
  --red: #E0554A;
  --red-soft: rgba(224,85,74,0.14);
  --p1: #34C77B;
  --p1-bg: #16301F;
  --p2: #7FB0DB;
  --p2-bg: #172333;
  --font-body: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
  --font-mono: 'IBM Plex Mono', ui-monospace, 'SF Mono', monospace;
}

* { box-sizing: border-box; }
html, body { margin: 0; padding: 0; background: var(--ink); color: var(--chalk); font-family: var(--font-body); -webkit-font-smoothing: antialiased; }
body { padding-top: env(safe-area-inset-top, 0px); }
button, input { font-family: inherit; }

.app { max-width: 460px; margin: 0 auto; min-height: 100vh; display: flex; flex-direction: column; }

.topbar {
  display: flex; align-items: center; gap: 10px;
  padding: 14px 14px 12px; position: sticky; top: 0; background: var(--ink); z-index: 20;
  border-bottom: 1px solid var(--line);
}
.icon-btn {
  width: 34px; height: 34px; border-radius: 9px; border: 1px solid var(--line);
  background: var(--ink-soft); color: var(--chalk-dim); display: flex; align-items: center; justify-content: center;
  cursor: pointer; flex-shrink: 0;
}
.topbar__title { flex: 1; font-size: 18px; font-weight: 800; margin: 0; letter-spacing: -0.01em; }
.mode-pill {
  font-family: var(--font-mono); font-size: 10px; font-weight: 700; letter-spacing: 0.06em;
  color: var(--green); background: var(--green-soft); border: 1px solid var(--green);
  border-radius: 999px; padding: 5px 10px; cursor: pointer; flex-shrink: 0;
}
.mode-pill[data-mode="demo"] { color: var(--chalk-dim); background: transparent; border-color: var(--line); }

.content { flex: 1; padding: 16px 14px 8px; }
.panel { margin-bottom: 22px; }
.panel__head { display: flex; align-items: center; justify-content: space-between; margin-bottom: 10px; gap: 8px; }
.panel__head h2 { font-size: 15px; font-weight: 700; margin: 0; display: flex; align-items: center; gap: 6px; }
.chip {
  font-family: var(--font-mono); font-size: 10px; font-weight: 700; letter-spacing: 0.04em;
  border: 1px solid var(--green); color: var(--green); background: var(--green-soft);
  border-radius: 999px; padding: 3px 9px;
}
.dot { width: 7px; height: 7px; border-radius: 50%; display: inline-block; }
.dot--live { background: var(--red); box-shadow: 0 0 0 3px var(--red-soft); }

.upload-row { display: flex; flex-direction: column; gap: 10px; margin-bottom: 12px; }
.upload-picker { display: flex; flex-direction: column; gap: 8px; }
.upload-or { text-align: center; font-size: 10.5px; color: var(--chalk-dim); text-transform: uppercase; letter-spacing: 0.06em; }
.upload-box {
  display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 6px;
  border: 1.5px dashed var(--line); border-radius: 16px; padding: 30px 16px; text-align: center;
  color: var(--chalk-dim); cursor: pointer; background: var(--ink-soft);
}
.upload-box__icon { color: var(--green); margin-bottom: 4px; }
.upload-box__title { color: var(--chalk); font-weight: 700; font-size: 14.5px; }
.upload-box__hint { font-size: 11.5px; }

.preview-box { background: var(--ink-soft); border: 1px solid var(--line); border-radius: 16px; padding: 14px; }
.preview-box__label { font-size: 11px; letter-spacing: 0.04em; text-transform: uppercase; color: var(--chalk-dim); margin-bottom: 10px; }
.preview-box__change {
  width: 100%; text-align: center; margin-top: 10px; background: none; border: none;
  color: var(--chalk-dim); font-size: 12px; text-decoration: underline; cursor: pointer; padding: 6px;
}

.ptable__head { display: flex; justify-content: space-between; align-items: center; font-size: 11.5px; color: var(--chalk-dim); margin-bottom: 8px; }
.ptable__round { font-weight: 600; }
.ptable__live { color: var(--red); font-weight: 700; display: flex; align-items: center; gap: 4px; font-size: 10.5px; letter-spacing: 0.04em; }
.prow { display: flex; align-items: center; gap: 10px; padding: 7px 0; }
.prow__flag { width: 26px; height: 26px; border-radius: 7px; flex-shrink: 0; display: flex; align-items: center; justify-content: center; font-weight: 800; font-size: 10.5px; }
.prow__flag--p1 { background: var(--p1-bg); color: var(--p1); }
.prow__flag--p2 { background: var(--p2-bg); color: var(--p2); }
.prow__name { flex: 1; font-size: 13.5px; font-weight: 600; min-width: 0; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.prow__serve { width: 7px; height: 7px; border-radius: 50%; background: var(--green); flex-shrink: 0; }
.prow__sets { display: flex; gap: 5px; }
.prow__set { font-family: var(--font-mono); font-size: 12.5px; color: var(--chalk-dim); width: 18px; text-align: center; }
.prow__point { font-family: var(--font-mono); font-size: 12.5px; background: var(--ink-raised); border-radius: 5px; padding: 3px 7px; min-width: 26px; text-align: center; }
.pmeta { font-size: 11.5px; color: var(--chalk-dim); padding: 6px 0 10px; border-bottom: 1px solid var(--line); margin-bottom: 10px; }
.pmarket { display: flex; gap: 8px; }
.pmarket__side { flex: 1; border-radius: 9px; padding: 9px 10px; }
.pmarket__side--p1 { background: var(--p1-bg); }
.pmarket__side--p2 { background: var(--p2-bg); }
.pmarket__pct { font-size: 15px; font-weight: 800; }
.pmarket__label { font-size: 10.5px; opacity: 0.85; }

.field { display: flex; flex-direction: column; gap: 5px; margin-bottom: 12px; }
.field__label { font-size: 11px; color: var(--chalk-dim); letter-spacing: 0.03em; }
.field__control { width: 100%; background: var(--ink-soft); border: 1px solid var(--line); border-radius: 10px; color: var(--chalk); padding: 11px 12px; font-size: 15px; }

.btn { font-weight: 700; font-size: 14px; border-radius: 10px; padding: 12px 16px; border: none; cursor: pointer; display: inline-flex; align-items: center; justify-content: center; gap: 8px; }
.btn--primary { background: var(--green); color: #06170F; }
.btn--primary:disabled, .btn.is-busy { background: var(--line); color: var(--chalk-dim); cursor: default; }
.btn--outline { background: transparent; color: var(--chalk); border: 1px solid var(--line); font-size: 13px; padding: 9px 14px; }
.btn--block { width: 100%; }
.btn--lg { font-size: 15px; padding: 14px; margin-bottom: 10px; }

.card--error { background: var(--red-soft); border: 1px solid var(--red); border-radius: 12px; padding: 14px; margin-top: 10px; }
.error__title { color: var(--red); font-weight: 700; font-size: 13.5px; margin-bottom: 4px; }
.error__msg { color: var(--chalk); font-size: 12.5px; white-space: pre-wrap; opacity: 0.9; }

.recent-scroll { display: flex; gap: 10px; overflow-x: auto; padding-bottom: 4px; margin: 0 -14px; padding-left: 14px; padding-right: 14px; scrollbar-width: none; }
.recent-scroll::-webkit-scrollbar { display: none; }
.recent-card {
  flex: 0 0 auto; width: 148px; background: var(--ink-soft); border: 1px solid var(--line);
  border-radius: 14px; padding: 12px; scroll-snap-align: start;
}
.recent-card.is-latest { border-color: var(--green); }
.recent-card__tournament { font-size: 10.5px; color: var(--chalk-dim); margin-bottom: 8px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.recent-card__avatars { display: flex; align-items: center; justify-content: center; gap: 4px; margin-bottom: 8px; }
.recent-card__names { font-size: 11.5px; text-align: center; font-weight: 600; margin-bottom: 6px; line-height: 1.3; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.recent-card__badge { display: block; text-align: center; font-size: 10px; font-weight: 800; letter-spacing: 0.03em; border-radius: 999px; padding: 3px 0; margin-bottom: 6px; }
.recent-card__pct { text-align: center; font-size: 15px; font-weight: 800; }
.recent-card__time { text-align: center; font-size: 10px; color: var(--chalk-dim); margin-top: 2px; }

.avatar { width: 34px; height: 34px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: 800; font-size: 12px; flex-shrink: 0; }
.avatar--p1 { background: var(--p1-bg); color: var(--p1); }
.avatar--p2 { background: var(--p2-bg); color: var(--p2); }
.avatar--lg { width: 84px; height: 84px; font-size: 24px; border: 2px solid var(--line); }

.badge { display: inline-block; }
.badge--buy { background: var(--green-soft); color: var(--green); }
.badge--wait { background: var(--amber-soft); color: var(--amber); }
.badge--avoid { background: var(--red-soft); color: var(--red); }

.hero { background: var(--ink-soft); border: 1px solid var(--line); border-radius: 18px; padding: 20px 16px; }
.hero__flanks { display: flex; align-items: flex-start; justify-content: space-between; margin-bottom: 4px; }
.hero__side { width: 84px; text-align: center; }
.hero__name { font-size: 12px; font-weight: 700; margin-top: 8px; line-height: 1.2; }
.hero__rank { font-size: 10.5px; color: var(--chalk-dim); margin-top: 2px; }
.hero__center { flex: 1; text-align: center; padding-top: 4px; }
.hero__label { font-size: 10.5px; color: var(--chalk-dim); letter-spacing: 0.06em; text-transform: uppercase; margin-bottom: 4px; }
.hero__winner { font-size: 19px; font-weight: 800; color: var(--green); margin-bottom: 8px; line-height: 1.15; }
.hero__pct { font-size: 40px; font-weight: 800; line-height: 1; }
.hero__pct-label { font-size: 11px; color: var(--chalk-dim); margin-top: 4px; }

.stat-row { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 8px; margin-top: 18px; }
.stat-pill { background: var(--ink-raised); border-radius: 12px; padding: 10px 8px; text-align: center; }
.stat-pill__value { font-size: 16px; font-weight: 800; }
.stat-pill__label { font-size: 9.5px; color: var(--chalk-dim); margin-top: 3px; line-height: 1.25; }
.suggested-stake { text-align: center; font-size: 13px; margin-top: 14px; padding: 10px; background: var(--green-soft); border-radius: 10px; }

.view-full {
  width: 100%; text-align: center; background: none; border: none; border-top: 1px solid var(--line);
  color: var(--chalk-dim); font-size: 12.5px; font-weight: 600; padding: 12px 0 2px; margin-top: 16px; cursor: pointer;
}
.hero-detail { margin-top: 12px; padding-top: 12px; border-top: 1px solid var(--line); font-size: 12.5px; color: var(--chalk-dim); line-height: 1.6; }
.hero-detail b { color: var(--chalk); }
.hero-detail[hidden] { display: none; }

.tabbar {
  position: sticky; bottom: 0; display: flex; background: var(--ink-soft);
  border-top: 1px solid var(--line); padding: 8px 4px calc(8px + env(safe-area-inset-bottom, 0px));
}
.tab {
  flex: 1; background: none; border: none; color: var(--chalk-dim); display: flex; flex-direction: column;
  align-items: center; gap: 3px; font-size: 10px; padding: 4px 0; cursor: pointer;
}
.tab.is-active { color: var(--green); }

.disclaimer { font-size: 10.5px; color: var(--chalk-dim); line-height: 1.5; padding: 0 14px 6px; margin: 0; text-align: center; }

:focus-visible { outline: 2px solid var(--green); outline-offset: 2px; }

@media (max-width: 360px) {
  .hero__pct { font-size: 34px; }
  .hero__side { width: 72px; }
  .avatar--lg { width: 72px; height: 72px; font-size: 20px; }
}
</style>
</head>
<body>

<div class="app">

  <header class="topbar">
    <button class="icon-btn" id="menuBtn" type="button" aria-label="Menu">
      <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M3 5h14M3 10h14M3 15h14" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/></svg>
    </button>
    <h1 class="topbar__title">Tennis Master</h1>
    <button class="mode-pill" id="modePill" type="button">DEMO</button>
  </header>

  <main class="content" id="content">

    <section class="panel" id="section-home">
      <div class="upload-row">
        <div class="upload-picker" id="uploadPicker">
          <label class="upload-box" id="dropzone">
            <input type="file" accept="image/*" id="fileInput" hidden />
            <svg width="30" height="30" viewBox="0 0 24 24" fill="none" class="upload-box__icon"><path d="M12 16V4M12 4l-4 4M12 4l4 4M4 16v2a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-2" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
            <span class="upload-box__title">Upload Match Screenshot</span>
            <span class="upload-box__hint">PNG or JPG</span>
          </label>
          <div class="upload-or">or</div>
          <label class="btn btn--outline btn--block" id="cameraBtnLabel">
            <input type="file" accept="image/*" capture="environment" id="cameraInput" hidden />
            Use Camera
          </label>
        </div>

        <div class="preview-box" id="previewBox" hidden>
          <div class="preview-box__label">Screenshot Preview</div>
          <div id="previewTable"></div>
          <button class="preview-box__change" id="btnChangePhoto" type="button">Tap to change screenshot</button>
        </div>
      </div>

      <label class="field field--bankroll">
        <span class="field__label">Paper Bankroll ($)</span>
        <input class="field__control" type="number" id="bankrollInput" value="1000" />
      </label>

      <button class="btn btn--primary btn--block btn--lg" id="btnAnalyze" disabled>
        <svg width="16" height="16" viewBox="0 0 20 20" fill="none"><path d="M3 13l4-4 3 3 6-7" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
        Analyze Match
      </button>

      <div class="card--error" id="errorCard" hidden>
        <div class="error__title">Couldn't complete the analysis</div>
        <div class="error__msg" id="errorMsg"></div>
      </div>
    </section>

    <section class="panel" id="section-analyses" hidden>
      <div class="panel__head">
        <h2>Recent Analyses</h2>
      </div>
      <div class="recent-scroll" id="recentScroll"></div>
    </section>

    <section class="panel" id="section-research" hidden>
      <div class="panel__head">
        <h2><span class="dot dot--live"></span> Latest Prediction</h2>
        <span class="chip" id="confChip"></span>
      </div>
      <div id="heroRoot"></div>
    </section>

  </main>

  <p class="disclaimer">
    Research runs with live web search — it can still miss things or misread the image. Double-check the market
    price and any injury news in-app before acting. Not financial advice.
  </p>

  <nav class="tabbar" id="tabbar">
    <button class="tab is-active" data-target="section-home" type="button">
      <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M3 9l7-6 7 6v7a1 1 0 0 1-1 1h-3v-5H7v5H4a1 1 0 0 1-1-1V9z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/></svg>
      <span>Home</span>
    </button>
    <button class="tab" data-target="section-analyses" type="button">
      <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M3 15l4-5 3 3 6-8M4 17h12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
      <span>Analyses</span>
    </button>
    <button class="tab" data-target="section-home" data-focus="fileInput" type="button">
      <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><circle cx="10" cy="10" r="6.5" stroke="currentColor" stroke-width="1.5"/><path d="M14.5 14.5L18 18" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
      <span>Research</span>
    </button>
    <button class="tab" data-target="section-analyses" type="button">
      <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><circle cx="10" cy="10" r="7" stroke="currentColor" stroke-width="1.5"/><path d="M10 6v4l3 2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
      <span>History</span>
    </button>
    <button class="tab" data-target="section-home" data-focus="bankrollInput" type="button">
      <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><rect x="3" y="6" width="14" height="9" rx="1.5" stroke="currentColor" stroke-width="1.5"/><path d="M3 9h14" stroke="currentColor" stroke-width="1.5"/></svg>
      <span>Bankroll</span>
    </button>
  </nav>

</div>

<script>
(() => {
  'use strict';

  const $ = (id) => document.getElementById(id);

  const state = {
    mode: localStorage.getItem('tm_mode') || 'demo',
    image: null,
    matchInfo: null,
    research: null,
    history: JSON.parse(localStorage.getItem('tm_history') || '[]'),
  };

  function clamp(v, lo, hi) { return Math.max(lo, Math.min(hi, v)); }
  function sleep(ms) { return new Promise((r) => setTimeout(r, ms)); }
  function escapeHtml(s) { return String(s ?? '').replace(/[&<>"']/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c])); }
  function initials(name) {
    const parts = String(name || '').trim().split(/\s+/).filter(Boolean);
    if (!parts.length) return '?';
    return (parts[0][0] + (parts[1] ? parts[1][0] : '')).toUpperCase();
  }
  function shortName(name) {
    const parts = String(name || '').trim().split(/\s+/).filter(Boolean);
    return parts.length ? parts[parts.length - 1] : name;
  }
  function relTime(iso) {
    const diff = Date.now() - new Date(iso).getTime();
    const m = Math.floor(diff / 60000);
    if (m < 1) return 'now';
    if (m < 60) return `${m}m ago`;
    const h = Math.floor(m / 60);
    if (h < 24) return `${h}h ago`;
    return `${Math.floor(h / 24)}d ago`;
  }
  function decisionColor(d) { return d === 'BUY' ? 'var(--green)' : d === 'WAIT' ? 'var(--amber)' : d === 'AVOID' ? 'var(--red)' : 'var(--chalk-dim)'; }

  const modePill = $('modePill');
  function renderMode() { modePill.textContent = state.mode.toUpperCase(); modePill.dataset.mode = state.mode; }
  modePill.addEventListener('click', () => {
    state.mode = state.mode === 'demo' ? 'live' : 'demo';
    localStorage.setItem('tm_mode', state.mode);
    renderMode();
  });
  renderMode();

  $('menuBtn').addEventListener('click', () => window.scrollTo({ top: 0, behavior: 'smooth' }));

  document.querySelectorAll('.tab').forEach((tab) => {
    tab.addEventListener('click', () => {
      document.querySelectorAll('.tab').forEach((t) => t.classList.remove('is-active'));
      tab.classList.add('is-active');
      const target = $(tab.dataset.target);
      if (target) target.scrollIntoView({ behavior: 'smooth', block: 'start' });
      const focusId = tab.dataset.focus;
      if (focusId) setTimeout(() => { const el = $(focusId); if (el) el.focus(); }, 350);
    });
  });

  function compressImage(file, maxDim = 1100, quality = 0.85) {
    return new Promise((resolve, reject) => {
      const reader = new FileReader();
      reader.onload = () => {
        const img = new Image();
        img.onload = () => {
          let { width, height } = img;
          if (width > maxDim || height > maxDim) {
            if (width > height) { height = Math.round(height * (maxDim / width)); width = maxDim; }
            else { width = Math.round(width * (maxDim / height)); height = maxDim; }
          }
          const canvas = document.createElement('canvas');
          canvas.width = width; canvas.height = height;
          canvas.getContext('2d').drawImage(img, 0, 0, width, height);
          const dataUrl = canvas.toDataURL('image/jpeg', quality);
          resolve({ dataUrl, base64: dataUrl.split(',')[1], mediaType: 'image/jpeg' });
        };
        img.onerror = () => reject(new Error("Couldn't load that image"));
        img.src = reader.result;
      };
      reader.onerror = () => reject(new Error("Couldn't read that file"));
      reader.readAsDataURL(file);
    });
  }

  function demoRead() {
    return {
      player1: 'Amy Stevens', player2: 'I Wen Wan', tournament: 'W15 Brisbane', round: '1st Round',
      live: true, sets: [{ p1: 6, p2: 4 }, { p1: 2, p2: 2 }], currentPoint: '30-30',
      server: 'player1', scoreSummary: '3rd set incoming — currently 2-2 in set 2, Stevens serving',
      marketPricePlayer1: 42, marketPricePlayer2: 60,
    };
  }
  function demoResearch() {
    return {
      player1Notes: 'WTA ~845, on a strong recent run — mostly straight-set first-round wins lately.',
      player2Notes: 'WTA ~1004, higher career-high but poor recent form, around a 20% win rate over her last 10.',
      player1Rank: 'WTA #845', player2Rank: 'WTA #1004',
      modelProbPlayer1: 52, confidenceScore: 3,
      reasoning: 'Split-set, tied-game situation between closely matched players — close to a genuine coin flip.',
    };
  }

  async function apiReadImage(image) {
    const res = await fetch('/api/read-image', {
      method: 'POST', headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ imageBase64: image.base64, mediaType: image.mediaType }),
    });
    const data = await res.json();
    if (!res.ok) throw new Error(data.error || `Request failed (${res.status})`);
    return data;
  }
  async function apiResearch(m) {
    const res = await fetch('/api/research', {
      method: 'POST', headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ player1: m.player1, player2: m.player2, tournament: m.tournament, scoreSummary: m.scoreSummary }),
    });
    const data = await res.json();
    if (!res.ok) throw new Error(data.error || `Request failed (${res.status})`);
    return data;
  }

  const uploadPicker = $('uploadPicker'), fileInput = $('fileInput'), cameraInput = $('cameraInput');
  const previewBox = $('previewBox'), previewTable = $('previewTable');
  const btnAnalyze = $('btnAnalyze');
  const errorCard = $('errorCard'), errorMsg = $('errorMsg');

  async function onFile(e) {
    const file = e.target.files && e.target.files[0];
    if (!file) return;
    errorCard.hidden = true;
    try {
      state.image = await compressImage(file);
    } catch (err) {
      showError(err.message || "Couldn't process that image");
      return;
    }

    uploadPicker.hidden = true;
    previewBox.hidden = false;
    previewTable.innerHTML = `<div class="pmeta" style="border-bottom:none;">Reading photo…</div>`;
    btnAnalyze.disabled = true;

    try {
      let info;
      if (state.mode === 'demo') { await sleep(600); info = demoRead(); }
      else info = await apiReadImage(state.image);

      if (!info.player1 || !info.player2) {
        throw new Error("Couldn't identify both players in this photo — try a clearer screenshot.");
      }
      state.matchInfo = info;
      previewTable.innerHTML = renderPreviewTable(info);
      btnAnalyze.disabled = false;
    } catch (err) {
      showError(`Reading the photo failed: ${err.message}`);
      uploadPicker.hidden = false;
      previewBox.hidden = true;
    }
  }
  fileInput.addEventListener('change', onFile);
  cameraInput.addEventListener('change', onFile);

  $('btnChangePhoto').addEventListener('click', () => {
    state.image = null; state.matchInfo = null;
    fileInput.value = ''; cameraInput.value = '';
    uploadPicker.hidden = false; previewBox.hidden = true;
    btnAnalyze.disabled = true;
  });

  function showError(msg) { errorCard.hidden = false; errorMsg.textContent = msg; }

  function renderPreviewTable(m) {
    const setsP1 = (m.sets || []).map((s) => s.p1);
    const setsP2 = (m.sets || []).map((s) => s.p2);
    let pt1 = '', pt2 = '';
    if (m.currentPoint && m.currentPoint.includes('-')) {
      const parts = m.currentPoint.split('-');
      pt1 = (parts[0] || '').trim(); pt2 = (parts[1] || '').trim();
    }
    const roundLabel = [m.tournament, m.round].filter(Boolean).join(' • ') || 'Match';
    const hasMarket = m.marketPricePlayer1 != null || m.marketPricePlayer2 != null;

    return `
      <div class="ptable__head">
        <span class="ptable__round">${escapeHtml(roundLabel)}</span>
        ${m.live ? '<span class="ptable__live"><span class="dot dot--live"></span>LIVE</span>' : ''}
      </div>
      <div class="prow">
        <div class="prow__flag prow__flag--p1">${initials(m.player1)}</div>
        <div class="prow__name">${escapeHtml(m.player1)}</div>
        ${m.server === 'player1' ? '<span class="prow__serve" title="serving"></span>' : ''}
        <div class="prow__sets">${setsP1.map((v) => `<span class="prow__set">${v}</span>`).join('')}</div>
        ${pt1 ? `<div class="prow__point">${escapeHtml(pt1)}</div>` : ''}
      </div>
      <div class="prow">
        <div class="prow__flag prow__flag--p2">${initials(m.player2)}</div>
        <div class="prow__name">${escapeHtml(m.player2)}</div>
        ${m.server === 'player2' ? '<span class="prow__serve" title="serving"></span>' : ''}
        <div class="prow__sets">${setsP2.map((v) => `<span class="prow__set">${v}</span>`).join('')}</div>
        ${pt2 ? `<div class="prow__point">${escapeHtml(pt2)}</div>` : ''}
      </div>
      ${m.scoreSummary ? `<div class="pmeta">${escapeHtml(m.scoreSummary)}</div>` : ''}
      ${hasMarket ? `
        <div class="pmarket">
          <div class="pmarket__side pmarket__side--p1">
            <div class="pmarket__pct">${m.marketPricePlayer1 != null ? Math.round(m.marketPricePlayer1) + '%' : '—'}</div>
            <div class="pmarket__label">${escapeHtml(shortName(m.player1))}</div>
          </div>
          <div class="pmarket__side pmarket__side--p2">
            <div class="pmarket__pct">${m.marketPricePlayer2 != null ? Math.round(m.marketPricePlayer2) + '%' : '—'}</div>
            <div class="pmarket__label">${escapeHtml(shortName(m.player2))}</div>
          </div>
        </div>` : `<div style="color:var(--chalk-dim);font-size:11.5px;">No market price visible in screenshot</div>`}
    `;
  }

  btnAnalyze.addEventListener('click', async () => {
    if (!state.matchInfo) return;
    errorCard.hidden = true;
    btnAnalyze.classList.add('is-busy');
    btnAnalyze.disabled = true;
    const originalLabel = btnAnalyze.innerHTML;
    btnAnalyze.textContent = 'Researching…';

    try {
      let research;
      if (state.mode === 'demo') { await sleep(1000); research = demoResearch(); }
      else research = await apiResearch(state.matchInfo);

      state.research = research;
      const decisionInfo = computeDecision(state.matchInfo, research);
      const tradeConfidence = computeTradeConfidence(research, decisionInfo);

      renderHero(state.matchInfo, research, decisionInfo, tradeConfidence, Number($('bankrollInput').value) || 0);
      renderConfChip(research.confidenceScore);
      $('section-research').hidden = false;

      saveHistory(state.matchInfo, research, decisionInfo);
      renderRecent();
      $('section-analyses').hidden = false;

      $('section-research').scrollIntoView({ behavior: 'smooth', block: 'start' });
    } catch (err) {
      showError(`Research failed: ${err.message}`);
    } finally {
      btnAnalyze.classList.remove('is-busy');
      btnAnalyze.disabled = false;
      btnAnalyze.innerHTML = originalLabel;
    }
  });

  function computeDecision(matchInfo, research) {
    const modelProb = clamp(Number(research.modelProbPlayer1 ?? 50), 0, 100);
    const side = modelProb >= 50 ? 'player1' : 'player2';
    const fair = side === 'player1' ? modelProb : 100 - modelProb;
    const market = side === 'player1' ? matchInfo.marketPricePlayer1 : matchInfo.marketPricePlayer2;
    if (market == null) return { decision: null, edge: null, value: null, side, fair, market: null };
    const edge = fair - market;
    let decision, value = null, pct = 0;
    if (edge < 3) decision = 'AVOID';
    else if (research.confidenceScore < 4) decision = 'WAIT';
    else {
      decision = 'BUY';
      if (edge >= 15) { value = 'Strong Value'; pct = 0.05; }
      else if (edge >= 8) { value = 'Good Value'; pct = 0.025; }
      else { value = 'Slight Value'; pct = 0.01; }
    }
    return { decision, edge, value, pct, side, fair, market };
  }

  function computeTradeConfidence(research, decisionInfo) {
    if (decisionInfo.edge == null) return null;
    const edgeScore = (clamp(decisionInfo.edge, 0, 20) / 20) * 10;
    return clamp(research.confidenceScore * 0.6 + edgeScore * 0.4, 1, 10);
  }

  function renderConfChip(score) {
    const chip = $('confChip');
    const tier = score >= 8 ? { t: 'High Confidence', c: 'var(--green)' } : score >= 5 ? { t: 'Medium Confidence', c: 'var(--amber)' } : { t: 'Low Confidence', c: 'var(--red)' };
    chip.textContent = tier.t;
    chip.style.color = tier.c; chip.style.borderColor = tier.c;
    chip.style.background = 'transparent';
  }

  function renderHero(m, r, decisionInfo, tradeConfidence, bankroll) {
    const modelProb = clamp(Number(r.modelProbPlayer1 ?? 50), 0, 100);
    const winnerSide = modelProb >= 50 ? 'player1' : 'player2';
    const winnerName = winnerSide === 'player1' ? m.player1 : m.player2;
    const winnerPct = winnerSide === 'player1' ? modelProb : 100 - modelProb;
    const stake = decisionInfo.decision === 'BUY' ? Math.round((bankroll || 0) * decisionInfo.pct) : 0;

    $('heroRoot').innerHTML = `
      <div class="hero">
        <div class="hero__flanks">
          <div class="hero__side">
            <div class="avatar avatar--lg avatar--p1">${initials(m.player1)}</div>
            <div class="hero__name">${escapeHtml(m.player1)}</div>
            ${r.player1Rank ? `<div class="hero__rank">${escapeHtml(r.player1Rank)}</div>` : ''}
          </div>
          <div class="hero__center">
            <div class="hero__label">Predicted Winner</div>
            <div class="hero__winner">${escapeHtml(winnerName)}</div>
            <div class="hero__pct">${Math.round(winnerPct)}%</div>
            <div class="hero__pct-label">Estimated Win Probability</div>
          </div>
          <div class="hero__side">
            <div class="avatar avatar--lg avatar--p2">${initials(m.player2)}</div>
            <div class="hero__name">${escapeHtml(m.player2)}</div>
            ${r.player2Rank ? `<div class="hero__rank">${escapeHtml(r.player2Rank)}</div>` : ''}
          </div>
        </div>

        <div class="stat-row">
          <div class="stat-pill">
            <div class="stat-pill__value">${r.confidenceScore}/10</div>
            <div class="stat-pill__label">Prediction Confidence</div>
          </div>
          <div class="stat-pill">
            <div class="stat-pill__value">${tradeConfidence != null ? tradeConfidence.toFixed(1) + '/10' : '—'}</div>
            <div class="stat-pill__label">Trade Confidence</div>
          </div>
          <div class="stat-pill">
            <div class="stat-pill__value" style="color:${decisionColor(decisionInfo.decision)}">${decisionInfo.decision || '—'}</div>
            <div class="stat-pill__label">${decisionInfo.value || (decisionInfo.decision ? '' : 'No market price')}</div>
          </div>
        </div>

        ${decisionInfo.decision === 'BUY' ? `<div class="suggested-stake">Suggested paper stake: <b>$${stake}</b> <span style="color:var(--chalk-dim);">(${Math.round(decisionInfo.pct * 100)}% of bankroll)</span></div>` : ''}

        <button class="view-full" id="btnViewFull" type="button">View Full Analysis ›</button>
        <div class="hero-detail" id="heroDetail" hidden>
          <div style="margin-bottom:6px;"><b>${escapeHtml(m.player1)}:</b> ${escapeHtml(r.player1Notes || '')}</div>
          <div style="margin-bottom:6px;"><b>${escapeHtml(m.player2)}:</b> ${escapeHtml(r.player2Notes || '')}</div>
          ${r.reasoning ? `<div style="font-style:italic;">${escapeHtml(r.reasoning)}</div>` : ''}
        </div>
      </div>`;

    $('btnViewFull').addEventListener('click', () => {
      const d = $('heroDetail');
      d.hidden = !d.hidden;
      $('btnViewFull').textContent = d.hidden ? 'View Full Analysis ›' : 'Hide Full Analysis ‹';
    });
  }

  function saveHistory(m, r, decisionInfo) {
    const modelProb = clamp(Number(r.modelProbPlayer1 ?? 50), 0, 100);
    const winProb = Math.round(modelProb >= 50 ? modelProb : 100 - modelProb);
    state.history.unshift({
      id: Date.now(), time: new Date().toISOString(),
      player1: m.player1, player2: m.player2, tournament: m.tournament,
      winProb, confidenceScore: r.confidenceScore, decision: decisionInfo.decision,
    });
    state.history = state.history.slice(0, 20);
    localStorage.setItem('tm_history', JSON.stringify(state.history));
  }

  function renderRecent() {
    const scroll = $('recentScroll');
    if (!state.history.length) { $('section-analyses').hidden = true; return; }
    scroll.innerHTML = state.history.map((h, i) => `
      <div class="recent-card ${i === 0 ? 'is-latest' : ''}">
        <div class="recent-card__tournament">${escapeHtml(h.tournament || '—')}</div>
        <div class="recent-card__avatars">
          <div class="avatar avatar--p1">${initials(h.player1)}</div>
          <div class="avatar avatar--p2">${initials(h.player2)}</div>
        </div>
        <div class="recent-card__names">${escapeHtml(shortName(h.player1))} vs ${escapeHtml(shortName(h.player2))}</div>
        ${h.decision ? `<span class="recent-card__badge badge badge--${h.decision.toLowerCase()}">${h.decision}</span>` : ''}
        <div class="recent-card__pct">${h.winProb}%</div>
        <div class="recent-card__time">${relTime(h.time)}</div>
      </div>`).join('');
  }
  if (state.history.length) { renderRecent(); $('section-analyses').hidden = false; }
})();
</script>
</body>
</html>
